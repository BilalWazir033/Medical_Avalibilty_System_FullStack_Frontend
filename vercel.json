{
  "rewrites": [
    {
      "source": "/socket.io/",
      "destination": "http://65.0.89.63/socket.io/"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://65.0.89.63/socket.io/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "http://65.0.89.63/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}